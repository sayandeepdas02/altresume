# Django Internal Setting
SECRET_KEY="your-secure-production-secret-key-here"
DEBUG="False"

# MongoDB Connectivity (e.g., MongoDB Atlas URI in production)
MONGO_URI="mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority"

# Authentication
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"

# OpenAI Access for Optimization Pipeline
OPENAI_API_KEY="sk-your-openai-api-key"

# Async Queue Backbone (e.g., Upstash or generic Redis cloud)
CELERY_BROKER_URL="rediss://default:password@host:port"
CELERY_RESULT_BACKEND="rediss://default:password@host:port"
